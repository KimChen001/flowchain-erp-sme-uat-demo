    "typecheck": "tsc --noEmit",
    "test": "node --test server/domain/*.test.mjs server/routes/*.test.mjs",
    "test:browser": "playwright test",
    "test:browser:ai": "playwright test tests/browser/ai-copilot.spec.ts",
