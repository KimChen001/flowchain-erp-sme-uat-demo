generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                     String    @id
  name                   String
  legalName              String?
  countryCode            String    @default("CN")
  locale                 String    @default("zh-CN")
  currency               String    @default("CNY")
  timezone               String    @default("Asia/Shanghai")
  defaultLanguage        String    @default("zh-CN")
  operationalSettings    Json      @default("{}")
  workspaceCompletedAt   DateTime?
  openingBalanceLockedAt DateTime?
  version                Int       @default(0)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  users                                 User[]
  suppliers                             Supplier[]
  items                                 Item[]
  warehouses                            Warehouse[]
  paymentTerms                          PaymentTerm[]
  taxCodes                              TaxCode[]
  actionDrafts                          ActionDraft[]
  auditLogs                             AuditLog[]
  aiEvidence                            AiEvidence[]
  purchaseRequests                      PurchaseRequest[]
  rfqs                                  Rfq[]
  supplierQuotations                    SupplierQuotation[]
  purchaseOrders                        PurchaseOrder[]
  receivingDocuments                    ReceivingDocument[]
  supplierInvoices                      SupplierInvoice[]
  threeWayMatches                       ThreeWayMatch[]
  financeMatchExceptions                FinanceMatchException[]
  payableObligations                    PayableObligation[]
  supplierCreditMemos                   SupplierCreditMemo[]
  customerInvoices                      CustomerInvoice[]
  receivableObligations                 ReceivableObligation[]
  customerCreditNotes                   CustomerCreditNote[]
  cashbookAccounts                      CashbookAccount[]
  settlementDocuments                   SettlementDocument[]
  settlementAllocations                 SettlementAllocation[]
  settlementAttachments                 SettlementAttachment[]
  partnerAdvances                       PartnerAdvance[]
  advanceApplications                   AdvanceApplicationDocument[]
  internalTransfers                     InternalTransferDocument[]
  cashbookEntries                       CashbookEntry[]
  stagedUploads                         StagedUpload[]
  receivingAttachments                  ReceivingAttachment[]
  domainChangeFeed                      DomainChangeFeed[]
  syncClients                           SyncClient[]
  syncSnapshotSessions                  SyncSnapshotSession[]
  documentLinks                         DocumentLink[]
  procurementFollowups                  ProcurementFollowup[]
  inventoryBalances                     InventoryBalance[]
  inventoryLots                         InventoryLot[]
  inventorySerials                      InventorySerial[]
  inventoryMovements                    InventoryMovement[]
  inventoryExceptions                   InventoryException[]
  commandExecutions                     BusinessCommandExecution[]
  userWarehouseScopes                   UserWarehouseScope[]
  roles                                 TenantRole[]
  rolePermissions                       TenantRolePermission[]
  userRoleAssignments                   UserRoleAssignment[]
  workspaceInvitations                  WorkspaceInvitation[]
  warehouseLocations                    WarehouseLocation[]
  importBatches                         ImportBatch[]
  importIssues                          ImportIssue[]
  salesOrders                           SalesOrder[]
  inventoryReservations                 InventoryReservation[]
  reservationEvents                     InventoryReservationEvent[]
  shipmentDocuments                     ShipmentDocument[]
  shipmentAllocations                   ShipmentAllocation[]
  quarantineBalances                    QuarantineInventoryBalance[]
  returnRequests                        ReturnRequest[]
  returnAuthorizations                  ReturnAuthorization[]
  returnPostings                        ReturnPostingDocument[]
  quarantineDispositionAllocations      QuarantineDispositionAllocation[]
  bankStatementMappings                 BankStatementMappingTemplate[]
  bankStatementImportBatches            BankStatementImportBatch[]
  bankStatementImportRows               BankStatementImportRow[]
  bankStatementLines                    BankStatementLine[]
  bankReconciliationCandidates          BankReconciliationCandidate[]
  bankReconciliationGroups              BankReconciliationGroup[]
  bankReconciliationBankAllocations     BankReconciliationBankLineAllocation[]
  bankReconciliationCashbookAllocations BankReconciliationCashbookAllocation[]
  bankReconciliationExceptions          BankReconciliationException[]
}

model User {
  id                 String    @id
  tenantId           String
  email              String
  name               String
  role               String    @default("buyer")
  jobTitle           String?
  status             String    @default("active")
  department         String?
  locale             String?
  languagePreference String?
  defaultWarehouseId String?
  profileCompletedAt DateTime?
  version            Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant               Tenant                      @relation(fields: [tenantId], references: [id])
  actionDrafts         ActionDraft[]
  auditLogs            AuditLog[]
  defaultWarehouse     Warehouse?                  @relation("UserDefaultWarehouse", fields: [defaultWarehouseId], references: [id], onDelete: Restrict)
  warehouseScopes      UserWarehouseScope[]
  roleAssignments      UserRoleAssignment[]        @relation("AssignedUser")
  roleAssignmentsMade  UserRoleAssignment[]        @relation("RoleAssignmentCreator")
  rolesCreated         TenantRole[]                @relation("RoleCreator")
  rolesUpdated         TenantRole[]                @relation("RoleUpdater")
  roleGrantsCreated    TenantRolePermission[]      @relation("RolePermissionCreator")
  invitationsSent      WorkspaceInvitation[]       @relation("InvitationInviter")
  invitationsAccepted  WorkspaceInvitation[]       @relation("InvitationAcceptor")
  syncClients          SyncClient[]
  syncSnapshotSessions SyncSnapshotSession[]
  importBatches        ImportBatch[]
  reservationsCreated  InventoryReservation[]      @relation("ReservationReservedBy")
  reservationEvents    InventoryReservationEvent[] @relation("ReservationEventActor")
  shipmentsPosted      ShipmentDocument[]          @relation("ShipmentPostedBy")
  shipmentsReversed    ShipmentDocument[]          @relation("ShipmentReversedBy")

  @@unique([tenantId, email])
  @@unique([tenantId, id])
  @@index([tenantId])
}

model TenantRole {
  id                String   @id
  tenantId          String
  roleKey           String
  name              String
  description       String?
  status            String   @default("active")
  isDefaultTemplate Boolean  @default(false)
  version           Int      @default(0)
  createdById       String?
  updatedById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User?                  @relation("RoleCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?                  @relation("RoleUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  permissions TenantRolePermission[]
  assignments UserRoleAssignment[]

  @@unique([tenantId, roleKey])
  @@unique([tenantId, id])
  @@index([tenantId, status])
}

model TenantRolePermission {
  id             String   @id
  tenantId       String
  roleId         String
  permissionCode String
  createdAt      DateTime @default(now())
  createdById    String?

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role      TenantRole @relation(fields: [tenantId, roleId], references: [tenantId, id], onDelete: Cascade)
  createdBy User?      @relation("RolePermissionCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([roleId, permissionCode])
  @@index([tenantId, permissionCode])
}

model UserRoleAssignment {
  id          String   @id
  tenantId    String
  userId      String
  roleId      String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  createdById String?

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User       @relation("AssignedUser", fields: [tenantId, userId], references: [tenantId, id], onDelete: Cascade)
  role      TenantRole @relation(fields: [tenantId, roleId], references: [tenantId, id], onDelete: Restrict)
  createdBy User?      @relation("RoleAssignmentCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([userId, roleId])
  @@index([tenantId, userId, status])
  @@index([tenantId, roleId, status])
}

model Supplier {
  id        String   @id
  tenantId  String
  code      String?
  name      String
  category  String?
  status    String   @default("active")
  riskLevel String?
  score     Decimal? @db.Decimal(10, 2)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  items  Item[]

  @@unique([tenantId, code])
  @@index([tenantId, name])
}

model Item {
  id                  String   @id
  tenantId            String
  sku                 String
  name                String
  category            String?
  unit                String?
  preferredSupplierId String?
  status              String   @default("active")
  safetyStock         Decimal? @db.Decimal(18, 4)
  reorderPoint        Decimal? @db.Decimal(18, 4)
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant               Tenant                       @relation(fields: [tenantId], references: [id])
  preferredSupplier    Supplier?                    @relation(fields: [preferredSupplierId], references: [id])
  salesOrderLines      SalesOrderLine[]
  reservations         InventoryReservation[]
  shipmentLines        ShipmentLine[]
  customerInvoiceLines CustomerInvoiceLine[]
  quarantineBalances   QuarantineInventoryBalance[]

  @@unique([tenantId, sku])
  @@index([tenantId, name])
}

model Warehouse {
  id        String   @id
  tenantId  String
  code      String
  name      String
  status    String   @default("active")
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant              Tenant                       @relation(fields: [tenantId], references: [id])
  defaultForUsers     User[]                       @relation("UserDefaultWarehouse")
  userScopes          UserWarehouseScope[]
  locations           WarehouseLocation[]
  reservations        InventoryReservation[]
  shipmentAllocations ShipmentAllocation[]
  quarantineBalances  QuarantineInventoryBalance[]

  @@unique([tenantId, code])
}

model WarehouseLocation {
  id          String   @id
  tenantId    String
  warehouseId String
  code        String
  locationKey String
  name        String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@unique([tenantId, warehouseId, locationKey])
  @@index([tenantId, warehouseId])
}

model ImportBatch {
  id             String    @id
  tenantId       String
  importType     String
  fileName       String
  fileHash       String
  status         String    @default("uploaded")
  totalRows      Int       @default(0)
  validRows      Int       @default(0)
  invalidRows    Int       @default(0)
  committedRows  Int       @default(0)
  createdById    String
  createdAt      DateTime  @default(now())
  committedAt    DateTime?
  idempotencyKey String?
  mapping        Json?
  summary        Json?
  normalizedRows Json?

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdBy User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  issues    ImportIssue[]

  @@unique([tenantId, importType, idempotencyKey])
  @@index([tenantId, status, createdAt])
}

model ImportIssue {
  id            String  @id
  tenantId      String
  importBatchId String
  rowNumber     Int
  field         String?
  code          String
  message       String
  rawValue      String?

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Restrict)

  @@index([tenantId, importBatchId, rowNumber])
}

model UserWarehouseScope {
  id          String   @id
  tenantId    String
  userId      String
  warehouseId String
  accessLevel String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@unique([tenantId, userId, warehouseId])
  @@index([tenantId, warehouseId])
}

model WorkspaceInvitation {
  id           String    @id
  tenantId     String
  email        String
  role         String
  tokenHash    String    @unique
  status       String    @default("pending")
  expiresAt    DateTime
  invitedById  String
  acceptedById String?
  createdAt    DateTime  @default(now())
  acceptedAt   DateTime?

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  invitedBy  User   @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: Restrict)
  acceptedBy User?  @relation("InvitationAcceptor", fields: [acceptedById], references: [id], onDelete: Restrict)

  @@index([tenantId, email, status])
}

model PaymentTerm {
  id        String   @id
  tenantId  String
  code      String
  name      String
  days      Int?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
}

model TaxCode {
  id        String   @id
  tenantId  String
  code      String
  name      String
  rate      Decimal? @db.Decimal(10, 4)
  taxType   String?
  region    String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
}

model ActionDraft {
  id                   String   @id
  tenantId             String
  type                 String
  title                String
  status               String   @default("preview")
  source               String?
  createdById          String?
  requiresConfirmation Boolean  @default(true)
  previewOnly          Boolean  @default(true)
  originEvidence       Json?
  payload              Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant      Tenant                  @relation(fields: [tenantId], references: [id])
  createdBy   User?                   @relation(fields: [createdById], references: [id])
  validations ActionDraftValidation[]
  auditTrail  ActionDraftAuditTrail[]

  @@index([tenantId, type, status])
  @@index([tenantId, createdAt])
}

model ActionDraftValidation {
  id            String   @id
  actionDraftId String
  ok            Boolean  @default(false)
  missingFields Json?
  warnings      Json?
  errors        Json?
  createdAt     DateTime @default(now())

  actionDraft ActionDraft @relation(fields: [actionDraftId], references: [id], onDelete: Cascade)

  @@index([actionDraftId])
}

model ActionDraftAuditTrail {
  id            String   @id
  actionDraftId String
  action        String
  actorId       String?
  summary       String?
  metadata      Json?
  createdAt     DateTime @default(now())

  actionDraft ActionDraft @relation(fields: [actionDraftId], references: [id], onDelete: Cascade)

  @@index([actionDraftId, createdAt])
}

model AuditLog {
  id         String   @id
  tenantId   String
  source     String
  module     String?
  action     String
  entityType String
  entityId   String
  actorId    String?
  summary    String
  metadata   Json?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  actor  User?  @relation(fields: [actorId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
}

model AiEvidence {
  id         String   @id
  tenantId   String
  sourceType String
  entityType String
  entityId   String
  label      String?
  payload    Json?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, entityType, entityId])
}

model PurchaseRequest {
  id           String    @id
  tenantId     String
  status       String    @default("draft")
  requester    String?
  buyer        String?
  supplierId   String?
  supplierName String?
  priority     String?
  requiredDate DateTime?
  amount       Decimal?  @db.Decimal(18, 4)
  currency     String    @default("CNY")
  reason       String?
  source       String?
  linkedRfqId  String?
  linkedPoId   String?
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant                @relation(fields: [tenantId], references: [id])
  lines  PurchaseRequestLine[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model PurchaseRequestLine {
  id                String   @id
  purchaseRequestId String
  itemId            String?
  sku               String?
  itemName          String?
  quantity          Decimal? @db.Decimal(18, 4)
  unit              String?
  unitPrice         Decimal? @db.Decimal(18, 4)
  amount            Decimal? @db.Decimal(18, 4)
  metadata          Json?

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)

  @@index([purchaseRequestId])
}

model Rfq {
  id                     String    @id
  tenantId               String
  title                  String
  category               String?
  status                 String    @default("active")
  supplierCount          Int       @default(0)
  respondedSupplierCount Int       @default(0)
  dueDate                DateTime?
  bestPrice              Decimal?  @db.Decimal(18, 4)
  awardedSupplier        String?
  supplierId             String?
  sourceRequestId        String?
  linkedPoId             String?
  currency               String    @default("CNY")
  metadata               Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  tenant     Tenant              @relation(fields: [tenantId], references: [id])
  lines      RfqLine[]
  quotations SupplierQuotation[]

  @@index([tenantId, status])
  @@index([tenantId, dueDate])
}

model RfqLine {
  id       String   @id
  rfqId    String
  itemId   String?
  sku      String?
  itemName String?
  quantity Decimal? @db.Decimal(18, 4)
  unit     String?
  metadata Json?

  rfq Rfq @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId])
}

model SupplierQuotation {
  id           String    @id
  tenantId     String
  rfqId        String?
  supplierId   String?
  supplierName String?
  status       String    @default("submitted")
  quotedAmount Decimal?  @db.Decimal(18, 4)
  currency     String    @default("CNY")
  submittedAt  DateTime?
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant                  @relation(fields: [tenantId], references: [id])
  rfq    Rfq?                    @relation(fields: [rfqId], references: [id])
  lines  SupplierQuotationLine[]

  @@index([tenantId, rfqId])
  @@index([tenantId, supplierName])
}

model SupplierQuotationLine {
  id                  String   @id
  supplierQuotationId String
  itemId              String?
  sku                 String?
  itemName            String?
  quantity            Decimal? @db.Decimal(18, 4)
  unit                String?
  unitPrice           Decimal? @db.Decimal(18, 4)
  amount              Decimal? @db.Decimal(18, 4)
  metadata            Json?

  supplierQuotation SupplierQuotation @relation(fields: [supplierQuotationId], references: [id], onDelete: Cascade)

  @@index([supplierQuotationId])
}

model PurchaseOrder {
  id                  String    @id
  tenantId            String
  status              String    @default("draft")
  supplierId          String?
  supplierName        String?
  sourceRequestId     String?
  sourceRfqId         String?
  expectedDate        DateTime?
  amount              Decimal?  @db.Decimal(18, 4)
  currency            String    @default("CNY")
  owner               String?
  priority            String?
  receivingBaseStatus String?
  version             Int       @default(0)
  metadata            Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant Tenant              @relation(fields: [tenantId], references: [id])
  lines  PurchaseOrderLine[]

  @@index([tenantId, status])
  @@index([tenantId, expectedDate])
}

model PurchaseOrderLine {
  id               String   @id
  purchaseOrderId  String
  itemId           String?
  sku              String?
  itemName         String?
  orderedQuantity  Decimal? @db.Decimal(18, 4)
  receivedQuantity Decimal? @db.Decimal(18, 4)
  version          Int      @default(0)
  unit             String?
  unitPrice        Decimal? @db.Decimal(18, 4)
  amount           Decimal? @db.Decimal(18, 4)
  metadata         Json?

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model ReceivingDocument {
  id             String    @id
  tenantId       String
  documentNumber String?
  poId           String?
  supplierId     String?
  supplierName   String?
  status         String    @default("receiving")
  workflowStatus String    @default("draft")
  postingStatus  String    @default("unposted")
  postedAt       DateTime?
  postedById     String?
  reversedAt     DateTime?
  reversedById   String?
  reversalReason String?
  version        Int       @default(0)
  arrivedAt      DateTime?
  receiver       String?
  warehouseId    String?
  currency       String    @default("CNY")
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant      Tenant                @relation(fields: [tenantId], references: [id])
  lines       ReceivingLine[]
  attachments ReceivingAttachment[]

  @@unique([tenantId, documentNumber])
  @@unique([tenantId, id])
  @@index([tenantId, status])
  @@index([tenantId, poId])
  @@index([tenantId, postingStatus])
}

model ReceivingLine {
  id                  String   @id
  receivingDocumentId String
  itemId              String?
  purchaseOrderLineId String?
  sku                 String?
  itemName            String?
  acceptedQty         Decimal? @db.Decimal(18, 4)
  rejectedQty         Decimal? @db.Decimal(18, 4)
  unit                String?
  warehouseId         String?
  location            String?
  locationKey         String   @default("")
  lotNumber           String?
  serialData          Json?
  version             Int      @default(0)
  metadata            Json?

  receivingDocument ReceivingDocument @relation(fields: [receivingDocumentId], references: [id], onDelete: Cascade)

  @@index([receivingDocumentId])
  @@index([purchaseOrderLineId])
}

model SupplierInvoice {
  id                 String    @id
  tenantId           String
  invoiceNumber      String?
  supplierId         String?
  supplierName       String?
  supplierSnapshot   Json?
  relatedPoId        String?
  relatedGrnId       String?
  invoiceDate        DateTime?
  dueDate            DateTime?
  subtotalAmount     Decimal?  @db.Decimal(18, 4)
  enteredTaxAmount   Decimal?  @db.Decimal(18, 4)
  totalAmount        Decimal?  @db.Decimal(18, 4)
  amount             Decimal?  @db.Decimal(18, 4)
  currency           String    @default("CNY")
  status             String    @default("draft")
  matchStatus        String?
  varianceAmount     Decimal?  @db.Decimal(18, 4)
  submittedAt        DateTime?
  submittedById      String?
  approvedAt         DateTime?
  approvedById       String?
  heldAt             DateTime?
  heldById           String?
  holdReason         String?
  cancelledAt        DateTime?
  cancelledById      String?
  cancellationReason String?
  version            Int       @default(0)
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant              Tenant                  @relation(fields: [tenantId], references: [id])
  lines               SupplierInvoiceLine[]
  matchRuns           ThreeWayMatch[]
  matchExceptions     FinanceMatchException[]
  payableObligation   PayableObligation?
  supplierCreditMemos SupplierCreditMemo[]

  @@index([tenantId, status])
  @@index([tenantId, relatedPoId])
  @@index([tenantId, supplierId, invoiceNumber])
}

model SupplierInvoiceLine {
  id                  String   @id
  supplierInvoiceId   String
  lineNumber          Int?
  purchaseOrderLineId String?
  receivingLineId     String?
  itemId              String?
  sku                 String?
  itemName            String?
  quantity            Decimal? @db.Decimal(18, 4)
  unit                String?
  unitPrice           Decimal? @db.Decimal(18, 4)
  lineAmount          Decimal? @db.Decimal(18, 4)
  enteredTaxAmount    Decimal? @db.Decimal(18, 4)
  amount              Decimal? @db.Decimal(18, 4)
  version             Int      @default(0)
  metadata            Json?

  supplierInvoice SupplierInvoice          @relation(fields: [supplierInvoiceId], references: [id], onDelete: Cascade)
  matchLines      ThreeWayMatchLine[]
  creditMemoLines SupplierCreditMemoLine[]

  @@index([supplierInvoiceId])
  @@index([purchaseOrderLineId])
  @@index([receivingLineId])
}

model ThreeWayMatch {
  id             String    @id
  tenantId       String
  matchNumber    String?
  poId           String?
  grnId          String?
  invoiceId      String?
  supplierId     String?
  supplierName   String?
  poAmount       Decimal?  @db.Decimal(18, 4)
  invoiceAmount  Decimal?  @db.Decimal(18, 4)
  varianceAmount Decimal?  @db.Decimal(18, 4)
  currency       String    @default("CNY")
  status         String    @default("pending")
  blockingReason String?
  matchedAt      DateTime?
  matchedById    String?
  version        Int       @default(0)
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant     Tenant                  @relation(fields: [tenantId], references: [id])
  invoice    SupplierInvoice?        @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
