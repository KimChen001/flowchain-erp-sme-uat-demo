generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id
  name      String
  locale    String   @default("zh-CN")
  currency  String   @default("CNY")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  suppliers            Supplier[]
  items                Item[]
  warehouses           Warehouse[]
  paymentTerms         PaymentTerm[]
  taxCodes             TaxCode[]
  actionDrafts         ActionDraft[]
  auditLogs            AuditLog[]
  aiEvidence           AiEvidence[]
  purchaseRequests     PurchaseRequest[]
  rfqs                 Rfq[]
  supplierQuotations   SupplierQuotation[]
  purchaseOrders       PurchaseOrder[]
  receivingDocuments   ReceivingDocument[]
  supplierInvoices     SupplierInvoice[]
  threeWayMatches      ThreeWayMatch[]
  documentLinks        DocumentLink[]
  procurementFollowups ProcurementFollowup[]
  inventoryBalances    InventoryBalance[]
  inventoryLots        InventoryLot[]
  inventorySerials     InventorySerial[]
  inventoryMovements   InventoryMovement[]
  inventoryExceptions  InventoryException[]
  commandExecutions    BusinessCommandExecution[]
}

model User {
  id         String   @id
  tenantId   String
  email      String
  name       String
  role       String   @default("buyer")
  department String?
  locale     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  actionDrafts ActionDraft[]
  auditLogs    AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Supplier {
  id        String   @id
  tenantId  String
  code      String?
  name      String
  category  String?
  status    String   @default("active")
  riskLevel String?
  score     Decimal? @db.Decimal(10, 2)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  items  Item[]

  @@unique([tenantId, code])
  @@index([tenantId, name])
}

model Item {
  id                  String   @id
  tenantId            String
  sku                 String
  name                String
  category            String?
  unit                String?
  preferredSupplierId String?
  status              String   @default("active")
  safetyStock         Decimal? @db.Decimal(18, 4)
  reorderPoint        Decimal? @db.Decimal(18, 4)
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  preferredSupplier Supplier? @relation(fields: [preferredSupplierId], references: [id])

  @@unique([tenantId, sku])
  @@index([tenantId, name])
}

model Warehouse {
  id        String   @id
  tenantId  String
  code      String
  name      String
  status    String   @default("active")
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
}

model PaymentTerm {
  id        String   @id
  tenantId  String
  code      String
  name      String
  days      Int?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
}

model TaxCode {
  id        String   @id
  tenantId  String
  code      String
  name      String
  rate      Decimal? @db.Decimal(10, 4)
  taxType   String?
  region    String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
}

model ActionDraft {
  id                   String   @id
  tenantId             String
  type                 String
  title                String
  status               String   @default("preview")
  source               String?
  createdById          String?
  requiresConfirmation Boolean  @default(true)
  previewOnly          Boolean  @default(true)
  originEvidence       Json?
  payload              Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant      Tenant                  @relation(fields: [tenantId], references: [id])
  createdBy   User?                   @relation(fields: [createdById], references: [id])
  validations ActionDraftValidation[]
  auditTrail  ActionDraftAuditTrail[]

  @@index([tenantId, type, status])
  @@index([tenantId, createdAt])
}

model ActionDraftValidation {
  id            String   @id
  actionDraftId String
  ok            Boolean  @default(false)
  missingFields Json?
  warnings      Json?
  errors        Json?
  createdAt     DateTime @default(now())

  actionDraft ActionDraft @relation(fields: [actionDraftId], references: [id], onDelete: Cascade)

  @@index([actionDraftId])
}

model ActionDraftAuditTrail {
  id            String   @id
  actionDraftId String
  action        String
  actorId       String?
  summary       String?
  metadata      Json?
  createdAt     DateTime @default(now())

  actionDraft ActionDraft @relation(fields: [actionDraftId], references: [id], onDelete: Cascade)

  @@index([actionDraftId, createdAt])
}

model AuditLog {
  id         String   @id
  tenantId   String
  source     String
  module     String?
  action     String
  entityType String
  entityId   String
  actorId    String?
  summary    String
  metadata   Json?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  actor  User?  @relation(fields: [actorId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
}

model AiEvidence {
  id         String   @id
  tenantId   String
  sourceType String
  entityType String
  entityId   String
  label      String?
  payload    Json?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, entityType, entityId])
}

model PurchaseRequest {
  id           String    @id
  tenantId     String
  status       String    @default("draft")
  requester    String?
  buyer        String?
  supplierId   String?
  supplierName String?
  priority     String?
  requiredDate DateTime?
  amount       Decimal?  @db.Decimal(18, 4)
  currency     String    @default("CNY")
  reason       String?
  source       String?
  linkedRfqId  String?
  linkedPoId   String?
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant                @relation(fields: [tenantId], references: [id])
  lines  PurchaseRequestLine[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model PurchaseRequestLine {
  id                String   @id
  purchaseRequestId String
  itemId            String?
  sku               String?
  itemName          String?
  quantity          Decimal? @db.Decimal(18, 4)
  unit              String?
  unitPrice         Decimal? @db.Decimal(18, 4)
  amount            Decimal? @db.Decimal(18, 4)
  metadata          Json?

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)

  @@index([purchaseRequestId])
}

model Rfq {
  id                     String    @id
  tenantId               String
  title                  String
  category               String?
  status                 String    @default("active")
  supplierCount          Int       @default(0)
  respondedSupplierCount Int       @default(0)
  dueDate                DateTime?
  bestPrice              Decimal?  @db.Decimal(18, 4)
  awardedSupplier        String?
  supplierId             String?
  sourceRequestId        String?
  linkedPoId             String?
  currency               String    @default("CNY")
  metadata               Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  tenant     Tenant              @relation(fields: [tenantId], references: [id])
  lines      RfqLine[]
  quotations SupplierQuotation[]

  @@index([tenantId, status])
  @@index([tenantId, dueDate])
}

model RfqLine {
  id       String   @id
  rfqId    String
  itemId   String?
  sku      String?
  itemName String?
  quantity Decimal? @db.Decimal(18, 4)
  unit     String?
  metadata Json?

  rfq Rfq @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  @@index([rfqId])
}

model SupplierQuotation {
  id           String    @id
  tenantId     String
  rfqId        String?
  supplierId   String?
  supplierName String?
  status       String    @default("submitted")
  quotedAmount Decimal?  @db.Decimal(18, 4)
  currency     String    @default("CNY")
  submittedAt  DateTime?
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant                  @relation(fields: [tenantId], references: [id])
  rfq    Rfq?                    @relation(fields: [rfqId], references: [id])
  lines  SupplierQuotationLine[]

  @@index([tenantId, rfqId])
  @@index([tenantId, supplierName])
}

model SupplierQuotationLine {
  id                  String   @id
  supplierQuotationId String
  itemId              String?
  sku                 String?
  itemName            String?
  quantity            Decimal? @db.Decimal(18, 4)
  unit                String?
  unitPrice           Decimal? @db.Decimal(18, 4)
  amount              Decimal? @db.Decimal(18, 4)
  metadata            Json?

  supplierQuotation SupplierQuotation @relation(fields: [supplierQuotationId], references: [id], onDelete: Cascade)

  @@index([supplierQuotationId])
}

model PurchaseOrder {
  id                  String    @id
  tenantId            String
  status              String    @default("draft")
  supplierId          String?
  supplierName        String?
  sourceRequestId     String?
  sourceRfqId         String?
  expectedDate        DateTime?
  amount              Decimal?  @db.Decimal(18, 4)
  currency            String    @default("CNY")
  owner               String?
  priority            String?
  receivingBaseStatus String?
  version             Int       @default(0)
  metadata            Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant Tenant              @relation(fields: [tenantId], references: [id])
  lines  PurchaseOrderLine[]

  @@index([tenantId, status])
  @@index([tenantId, expectedDate])
}

model PurchaseOrderLine {
  id               String   @id
  purchaseOrderId  String
  itemId           String?
  sku              String?
  itemName         String?
  orderedQuantity  Decimal? @db.Decimal(18, 4)
  receivedQuantity Decimal? @db.Decimal(18, 4)
  version          Int      @default(0)
  unit             String?
  unitPrice        Decimal? @db.Decimal(18, 4)
  amount           Decimal? @db.Decimal(18, 4)
  metadata         Json?

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model ReceivingDocument {
  id             String    @id
  tenantId       String
  documentNumber String?
  poId           String?
  supplierId     String?
  supplierName   String?
  status         String    @default("receiving")
  workflowStatus String    @default("draft")
  postingStatus  String    @default("unposted")
  postedAt       DateTime?
  postedById     String?
  reversedAt     DateTime?
  reversedById   String?
  reversalReason String?
  version        Int       @default(0)
  arrivedAt      DateTime?
  receiver       String?
  warehouseId    String?
  currency       String    @default("CNY")
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  lines  ReceivingLine[]

  @@unique([tenantId, documentNumber])
  @@index([tenantId, status])
  @@index([tenantId, poId])
  @@index([tenantId, postingStatus])
}

model ReceivingLine {
  id                  String   @id
  receivingDocumentId String
  itemId              String?
  purchaseOrderLineId String?
  sku                 String?
  itemName            String?
  acceptedQty         Decimal? @db.Decimal(18, 4)
  rejectedQty         Decimal? @db.Decimal(18, 4)
  unit                String?
  warehouseId         String?
  location            String?
  locationKey         String   @default("")
  lotNumber           String?
  serialData          Json?
  version             Int      @default(0)
  metadata            Json?

  receivingDocument ReceivingDocument @relation(fields: [receivingDocumentId], references: [id], onDelete: Cascade)

  @@index([receivingDocumentId])
  @@index([purchaseOrderLineId])
}

model SupplierInvoice {
  id             String    @id
  tenantId       String
  supplierId     String?
  supplierName   String?
  relatedPoId    String?
  relatedGrnId   String?
  invoiceDate    DateTime?
  dueDate        DateTime?
  amount         Decimal?  @db.Decimal(18, 4)
  currency       String    @default("CNY")
  status         String    @default("pending")
  matchStatus    String?
  varianceAmount Decimal?  @db.Decimal(18, 4)
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant                @relation(fields: [tenantId], references: [id])
  lines  SupplierInvoiceLine[]

  @@index([tenantId, status])
  @@index([tenantId, relatedPoId])
}

model SupplierInvoiceLine {
  id                String   @id
  supplierInvoiceId String
  itemId            String?
  sku               String?
  itemName          String?
  quantity          Decimal? @db.Decimal(18, 4)
  unit              String?
  unitPrice         Decimal? @db.Decimal(18, 4)
  amount            Decimal? @db.Decimal(18, 4)
  metadata          Json?

  supplierInvoice SupplierInvoice @relation(fields: [supplierInvoiceId], references: [id], onDelete: Cascade)

  @@index([supplierInvoiceId])
}

model ThreeWayMatch {
  id             String   @id
  tenantId       String
  poId           String?
  grnId          String?
  invoiceId      String?
  supplierId     String?
  supplierName   String?
  poAmount       Decimal? @db.Decimal(18, 4)
  invoiceAmount  Decimal? @db.Decimal(18, 4)
  varianceAmount Decimal? @db.Decimal(18, 4)
  currency       String   @default("CNY")
  status         String   @default("pending")
  blockingReason String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, invoiceId])
}

model DocumentLink {
  id           String   @id
  tenantId     String
  sourceType   String
  sourceId     String
  targetType   String
  targetId     String
  relationship String
  status       String?
  metadata     Json?
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, sourceType, sourceId])
  @@index([tenantId, targetType, targetId])
}

model ProcurementFollowup {
  id           String    @id
  tenantId     String
  type         String
  severity     String
  status       String    @default("open")
  owner        String?
  title        String
  message      String?
  dueDate      DateTime?
  supplierId   String?
  supplierName String?
  documentType String
  documentId   String
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status, severity])
  @@index([tenantId, documentType, documentId])
}

model InventoryBalance {
  id                String   @id
  tenantId          String
  itemId            String?
  sku               String
  itemName          String?
  warehouseId       String?
  warehouseKey      String   @default("")
  location          String?
  locationKey       String   @default("")
  availableQuantity Decimal? @db.Decimal(18, 4)
  onHandQuantity    Decimal? @db.Decimal(18, 4)
  reservedQuantity  Decimal? @db.Decimal(18, 4)
  safetyStock       Decimal? @db.Decimal(18, 4)
  reorderPoint      Decimal? @db.Decimal(18, 4)
  unit              String?
  status            String?
  riskLevel         String?
  version           Int      @default(0)
  metadata          Json?
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, sku, warehouseKey, locationKey])
  @@index([tenantId, sku])
  @@index([tenantId, warehouseId])
}

model InventoryLot {
  id             String    @id
  tenantId       String
  itemId         String?
  sku            String
  itemName       String?
  warehouseId    String?
  location       String?
  quantity       Decimal?  @db.Decimal(18, 4)
  qaStatus       String?
  expiryDate     DateTime?
  supplierId     String?
  supplierName   String?
  sourceDocument String?
  status         String    @default("available")
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, sku])
  @@index([tenantId, warehouseId])
}

model InventorySerial {
  id             String   @id
  tenantId       String
  itemId         String?
  sku            String
  itemName       String?
  warehouseId    String?
  location       String?
  status         String   @default("in_stock")
  owner          String?
  sourceDocument String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, sku])
  @@index([tenantId, status])
}

model InventoryMovement {
  id                   String    @id
  tenantId             String
  itemId               String?
  sku                  String
  itemName             String?
  warehouseId          String?
  location             String?
  locationKey          String    @default("")
  movementType         String
  movementLabel        String?
  movementDate         DateTime?
  sourceDocument       String?
  sourceDocumentType   String?
  sourceDocumentId     String?
  sourceDocumentLineId String?
  quantityIn           Decimal?  @db.Decimal(18, 4)
  quantityOut          Decimal?  @db.Decimal(18, 4)
  adjustmentQty        Decimal?  @db.Decimal(18, 4)
  status               String    @default("registered")
  owner                String?
  unit                 String?
  relatedPoId          String?
  relatedGrnId         String?
  relatedReturnId      String?
  relatedSalesOrderId  String?
  postingBatchId       String?
  reversalOfMovementId String?   @unique
  reversedByMovementId String?   @unique
  actorId              String?
  occurredAt           DateTime  @default(now())
  inventoryImpact      String?
  reason               String?
  evidence             Json?
  timeline             Json?
  metadata             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, movementType, sourceDocumentLineId])
  @@index([tenantId, sku])
  @@index([tenantId, movementDate])
  @@index([tenantId, status])
  @@index([tenantId, relatedGrnId, movementType])
  @@index([tenantId, sku, warehouseId, locationKey])
}

model BusinessCommandExecution {
  id             String    @id
  tenantId       String
  commandType    String
  idempotencyKey String
  requestHash    String
  status         String    @default("pending")
  entityType     String?
  entityId       String?
  resultPayload  Json?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, commandType, idempotencyKey])
  @@index([tenantId, entityType, entityId])
}

model InventoryException {
  id               String   @id
  tenantId         String
  type             String
  itemId           String?
  sku              String?
  itemName         String?
  warehouseId      String?
  location         String?
  quantityImpact   Decimal? @db.Decimal(18, 4)
  unit             String?
  status           String   @default("open")
  owner            String?
  linkedMovementId String?
  linkedDocument   String?
  nextAction       String?
  reason           String?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, sku])
}
