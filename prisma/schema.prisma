  sourceQuantity       Decimal? @db.Decimal(18, 4)
  sourceWarehouseIds   Json?
  itemId               String
  sku                  String
  itemName             String
  requestedQuantity    Decimal  @db.Decimal(18, 4)
  unit                 String?
  reasonCode           String
  conditionCode        String?
  version              Int      @default(0)
  metadata             Json?

  returnRequest      ReturnRequest             @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  authorizationLines ReturnAuthorizationLine[]

  @@unique([returnRequestId, sourceDocumentLineId])
  @@index([returnRequestId])
  @@index([itemId, sku])
}

model ReturnAuthorization {
  id                  String    @id
  tenantId            String
  authorizationNumber String
  returnRequestId     String
  workflowStatus      String    @default("draft")
  authorizedAt        DateTime?
  authorizedById      String?
  rejectedAt          DateTime?
  rejectedById        String?
  rejectionReason     String?
  cancelledAt         DateTime?
  cancelledById       String?
  cancellationReason  String?
  expiresAt           DateTime?
  expiredAt           DateTime?
  expiredById         String?
  version             Int       @default(0)
  metadata            Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant        Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  returnRequest ReturnRequest             @relation(fields: [returnRequestId], references: [id], onDelete: Restrict)
  lines         ReturnAuthorizationLine[]
  postings      ReturnPostingDocument[]

  @@unique([tenantId, authorizationNumber])
  @@index([tenantId, returnRequestId])
  @@index([tenantId, workflowStatus])
  @@index([tenantId, createdAt])
}

model ReturnAuthorizationLine {
  id                    String  @id
  returnAuthorizationId String
  returnRequestLineId   String
  authorizedQuantity    Decimal @db.Decimal(18, 4)
  dispositionRoute      String
  version               Int     @default(0)
  metadata              Json?

  returnAuthorization ReturnAuthorization @relation(fields: [returnAuthorizationId], references: [id], onDelete: Cascade)
  returnRequestLine   ReturnRequestLine   @relation(fields: [returnRequestLineId], references: [id], onDelete: Restrict)
  postingLines        ReturnPostingLine[]

  @@unique([returnAuthorizationId, returnRequestLineId])
  @@index([returnAuthorizationId])
  @@index([returnRequestLineId])
}

model ReturnPostingDocument {
  id                    String    @id
  tenantId              String
  postingNumber         String
  returnAuthorizationId String
  postingType           String
  workflowStatus        String    @default("draft")
  postingStatus         String    @default("unposted")
  warehouseId           String
  version               Int       @default(0)
  readyAt               DateTime?
  readyById             String?
  cancelledAt           DateTime?
  cancelledById         String?
  postedAt              DateTime?
  postedById            String?
  reversedAt            DateTime?
  reversedById          String?
  reversalReason        String?
  cancellationReason    String?
  metadata              Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  returnAuthorization ReturnAuthorization  @relation(fields: [returnAuthorizationId], references: [id], onDelete: Restrict)
  lines               ReturnPostingLine[]
  supplierCreditMemos SupplierCreditMemo[]
  customerCreditNotes CustomerCreditNote[]

  @@unique([tenantId, postingNumber])
  @@index([tenantId, returnAuthorizationId])
  @@index([tenantId, postingType, postingStatus])
  @@index([tenantId, warehouseId])
  @@index([tenantId, createdAt])
}

model ReturnPostingLine {
  id                            String  @id
  returnPostingId               String
  returnAuthorizationLineId     String
  itemId                        String
  sku                           String
  itemName                      String
  quantity                      Decimal @db.Decimal(18, 4)
  unit                          String?
  warehouseId                   String
  location                      String?
  locationKey                   String  @default("")
  inventoryBalanceId            String?
  quarantineBalanceId           String?
  destinationInventoryBalanceId String?
  version                       Int     @default(0)
  metadata                      Json?

  returnPosting               ReturnPostingDocument       @relation(fields: [returnPostingId], references: [id], onDelete: Cascade)
  returnAuthorizationLine     ReturnAuthorizationLine     @relation(fields: [returnAuthorizationLineId], references: [id], onDelete: Restrict)
  inventoryBalance            InventoryBalance?           @relation("ReturnPostingSourceInventoryBalance", fields: [inventoryBalanceId], references: [id], onDelete: Restrict)
  quarantineBalance           QuarantineInventoryBalance? @relation(fields: [quarantineBalanceId], references: [id], onDelete: Restrict)
  destinationInventoryBalance InventoryBalance?           @relation("ReturnPostingDestinationInventoryBalance", fields: [destinationInventoryBalanceId], references: [id], onDelete: Restrict)
  supplierCreditMemoLines     SupplierCreditMemoLine[]
  customerCreditNoteLines     CustomerCreditNoteLine[]

  @@unique([returnPostingId, returnAuthorizationLineId])
  @@index([returnPostingId])
  @@index([returnAuthorizationLineId])
  @@index([inventoryBalanceId])
  @@index([quarantineBalanceId])
  @@index([destinationInventoryBalanceId])
  @@index([warehouseId, locationKey])
}

model QuarantineDispositionAllocation {
  id                   String    @id
  tenantId             String
  quarantineBalanceId  String
  sourceMovementId     String
  consumerMovementId   String
  quantity             Decimal   @db.Decimal(18, 4)
  status               String    @default("active")
  reversedAt           DateTime?
  reversedByMovementId String?
  metadata             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant             Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  quarantineBalance  QuarantineInventoryBalance @relation(fields: [quarantineBalanceId], references: [id], onDelete: Restrict)
  sourceMovement     InventoryMovement          @relation("QuarantineDispositionSource", fields: [sourceMovementId], references: [id], onDelete: Restrict)
  consumerMovement   InventoryMovement          @relation("QuarantineDispositionConsumer", fields: [consumerMovementId], references: [id], onDelete: Restrict)
  reversedByMovement InventoryMovement?         @relation("QuarantineDispositionReversal", fields: [reversedByMovementId], references: [id], onDelete: Restrict)

  @@unique([sourceMovementId, consumerMovementId])
  @@index([tenantId, quarantineBalanceId, status])
  @@index([sourceMovementId, status])
  @@index([consumerMovementId, status])
}

model BusinessCommandExecution {
  id             String    @id
  tenantId       String
  commandType    String
  idempotencyKey String
  requestHash    String
  status         String    @default("pending")
  entityType     String?
  entityId       String?
  resultPayload  Json?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  tenant            Tenant                      @relation(fields: [tenantId], references: [id])
  reservationEvents InventoryReservationEvent[]

  @@unique([tenantId, commandType, idempotencyKey])
  @@index([tenantId, entityType, entityId])
}

model SalesOrder {
  id                String    @id
  tenantId          String
  orderNumber       String
  customerId        String?
  customerName      String
  workflowStatus    String    @default("draft")
  reservationStatus String    @default("not_reserved")
  fulfillmentStatus String    @default("not_fulfilled")
  promisedDate      DateTime?
  currency          String
  version           Int       @default(0)
  metadata          Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  lines            SalesOrderLine[]
  reservations     InventoryReservation[]
  shipments        ShipmentDocument[]
  customerInvoices CustomerInvoice[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId, workflowStatus])
  @@index([tenantId, reservationStatus])
  @@index([tenantId, fulfillmentStatus])
  @@index([tenantId, promisedDate])
}

model SalesOrderLine {
  id                String   @id
  salesOrderId      String
  itemId            String
  sku               String
  itemName          String
  orderedQuantity   Decimal  @db.Decimal(18, 4)
  reservedQuantity  Decimal  @default(0) @db.Decimal(18, 4)
  fulfilledQuantity Decimal  @default(0) @db.Decimal(18, 4)
  unit              String
  unitPrice         Decimal? @db.Decimal(18, 4)
  amount            Decimal? @db.Decimal(18, 4)
  version           Int      @default(0)
  metadata          Json?

  salesOrder           SalesOrder             @relation(fields: [salesOrderId], references: [id], onDelete: Restrict)
  item                 Item                   @relation(fields: [itemId], references: [id], onDelete: Restrict)
  reservations         InventoryReservation[]
  shipmentLines        ShipmentLine[]
  customerInvoiceLines CustomerInvoiceLine[]

  @@index([salesOrderId])
  @@index([itemId, sku])
}

model InventoryReservation {
  id                String   @id
  tenantId          String
  salesOrderId      String
  salesOrderLineId  String
  itemId            String
  sku               String
  warehouseId       String
  location          String?
  locationKey       String   @default("")
  reservedQuantity  Decimal  @db.Decimal(18, 4)
  allocatedQuantity Decimal  @default(0) @db.Decimal(18, 4)
  consumedQuantity  Decimal  @default(0) @db.Decimal(18, 4)
  releasedQuantity  Decimal  @default(0) @db.Decimal(18, 4)
  status            String   @default("active")
  version           Int      @default(0)
  reservedById      String
  reservedAt        DateTime @default(now())
  updatedAt         DateTime @updatedAt
  metadata          Json?

  tenant         Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  salesOrder     SalesOrder                  @relation(fields: [salesOrderId], references: [id], onDelete: Restrict)
  salesOrderLine SalesOrderLine              @relation(fields: [salesOrderLineId], references: [id], onDelete: Restrict)
  item           Item                        @relation(fields: [itemId], references: [id], onDelete: Restrict)
  warehouse      Warehouse                   @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  reservedBy     User                        @relation("ReservationReservedBy", fields: [reservedById], references: [id], onDelete: Restrict)
  events         InventoryReservationEvent[]
  allocations    ShipmentAllocation[]

  @@index([tenantId, salesOrderId])
  @@index([tenantId, salesOrderLineId])
  @@index([tenantId, sku, warehouseId, locationKey])
  @@index([tenantId, status])
}

model InventoryReservationEvent {
  id                 String   @id
  tenantId           String
  reservationId      String
  eventType          String
  quantity           Decimal  @db.Decimal(18, 4)
  commandType        String
  commandExecutionId String?
  actorId            String
  reason             String?
  metadata           Json?
  createdAt          DateTime @default(now())

  tenant           Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  reservation      InventoryReservation      @relation(fields: [reservationId], references: [id], onDelete: Restrict)
  actor            User                      @relation("ReservationEventActor", fields: [actorId], references: [id], onDelete: Restrict)
  commandExecution BusinessCommandExecution? @relation(fields: [commandExecutionId], references: [id], onDelete: Restrict)

  @@index([tenantId, reservationId, createdAt])
  @@index([tenantId, commandExecutionId])
}

model ShipmentDocument {
  id             String    @id
  tenantId       String
  shipmentNumber String
  salesOrderId   String
  workflowStatus String    @default("draft")
  postingStatus  String    @default("unposted")
  postedAt       DateTime?
  postedById     String?
  reversedAt     DateTime?
  reversedById   String?
  reversalReason String?
  version        Int       @default(0)
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  salesOrder       SalesOrder        @relation(fields: [salesOrderId], references: [id], onDelete: Restrict)
  postedBy         User?             @relation("ShipmentPostedBy", fields: [postedById], references: [id], onDelete: Restrict)
  reversedBy       User?             @relation("ShipmentReversedBy", fields: [reversedById], references: [id], onDelete: Restrict)
  lines            ShipmentLine[]
  customerInvoices CustomerInvoice[]

  @@unique([tenantId, shipmentNumber])
  @@index([tenantId, salesOrderId])
  @@index([tenantId, postingStatus])
  @@index([tenantId, workflowStatus])
}

model ShipmentLine {
  id                String  @id
  shipmentId        String
  salesOrderLineId  String
  itemId            String
  sku               String
  requestedQuantity Decimal @db.Decimal(18, 4)
  postedQuantity    Decimal @default(0) @db.Decimal(18, 4)
  unit              String
  version           Int     @default(0)
  metadata          Json?

  shipment             ShipmentDocument      @relation(fields: [shipmentId], references: [id], onDelete: Restrict)
  salesOrderLine       SalesOrderLine        @relation(fields: [salesOrderLineId], references: [id], onDelete: Restrict)
  item                 Item                  @relation(fields: [itemId], references: [id], onDelete: Restrict)
  allocations          ShipmentAllocation[]
  customerInvoiceLines CustomerInvoiceLine[]

  @@index([shipmentId])
  @@index([salesOrderLineId])
}

model ShipmentAllocation {
  id             String  @id
  tenantId       String
  shipmentLineId String
  reservationId  String
  warehouseId    String
  location       String?
  locationKey    String  @default("")
  quantity       Decimal @db.Decimal(18, 4)
  status         String  @default("allocated")
  version        Int     @default(0)
  metadata       Json?

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  shipmentLine ShipmentLine         @relation(fields: [shipmentLineId], references: [id], onDelete: Restrict)
  reservation  InventoryReservation @relation(fields: [reservationId], references: [id], onDelete: Restrict)
  warehouse    Warehouse            @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@index([tenantId, shipmentLineId])
  @@index([tenantId, reservationId])
  @@index([tenantId, warehouseId, locationKey])
  @@index([tenantId, status])
}

model InventoryException {
  id               String   @id
  tenantId         String
  type             String
  itemId           String?
  sku              String?
  itemName         String?
  warehouseId      String?
  location         String?
  quantityImpact   Decimal? @db.Decimal(18, 4)
  unit             String?
  status           String   @default("open")
  owner            String?
  linkedMovementId String?
  linkedDocument   String?
  nextAction       String?
  reason           String?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, sku])
}
