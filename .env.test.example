# Use only a dedicated, disposable PostgreSQL database. Never point this at a
# development, staging, or production business database.
DATABASE_URL_TEST="postgresql://test_user:replace-me@127.0.0.1:55432/flowchain_receiving_test?schema=public"
FLOWCHAIN_REQUIRE_REAL_POSTGRES_TESTS=true
FLOWCHAIN_ALLOW_LOCAL_ACTOR_BOOTSTRAP=true
FLOWCHAIN_ENABLE_DB_BANK_RECONCILIATION=true
FLOWCHAIN_BANK_IMPORT_MAX_FILE_BYTES=20971520
FLOWCHAIN_BANK_IMPORT_MAX_ROWS=10000
FLOWCHAIN_BANK_IMPORT_MAX_SHEETS=3
