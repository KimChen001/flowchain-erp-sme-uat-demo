OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-5-mini
OPENAI_PROXY_URL=http://127.0.0.1:15236

# Persistence defaults to JSON/demo data. Database mode is opt-in.
FLOWCHAIN_PERSISTENCE_MODE=json
# DATABASE_URL=postgresql://user:password@localhost:5432/flowchain
# Server-owned tenant context for local signed sessions and explicit test identity.
FLOWCHAIN_DEFAULT_TENANT_ID=tenant-flowchain-sme
FLOWCHAIN_ALLOW_LOCAL_ACTOR_BOOTSTRAP=false
# Formal receiving post/reverse remains off unless database mode is active too.
FLOWCHAIN_ENABLE_DB_RECEIVING_POSTING=false
# DATABASE_URL_TEST=postgresql://user:password@localhost:5432/flowchain_test

# Optional: use Doubao / Volcengine Ark instead of OpenAI
AI_PROVIDER=doubao
ARK_API_KEY=your-ark-api-key-here
ARK_MODEL=doubao-seed-2-0-lite-260215
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
